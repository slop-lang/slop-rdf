# Intra-domain taxonomy (synthesis subClassOf hierarchy).
:Service rdfs:subClassOf :Component .
:Module rdfs:subClassOf :Component .
:InterfaceDefinition rdfs:subClassOf :Interface .

# Domain relations (synthesis taxonomy).
:softwareSystemContains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:domain :SoftwareSystem ;
    rdfs:range :Subsystem ;
    rdfs:subPropertyOf obo:BFO_0000178 {| trivyn:confidence "0.70"^^xsd:decimal ; trivyn:parentLabel "has continuant part" ; trivyn:rrfRank "2"^^xsd:integer ; skos:historyNote "Aligned to has continuant part via embedding similarity" ; dcterms:created "2026-06-16T19:35:29Z"^^xsd:dateTime |}.
:subsystemContains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:domain :Subsystem ;
    rdfs:range :Component ;
    rdfs:subPropertyOf obo:BFO_0000178 {| trivyn:confidence "0.70"^^xsd:decimal ; trivyn:parentLabel "has continuant part" ; trivyn:rrfRank "2"^^xsd:integer ; skos:historyNote "Aligned to has continuant part via embedding similarity" ; dcterms:created "2026-06-16T19:35:29Z"^^xsd:dateTime |}.
:dependsOn a owl:ObjectProperty ;
    rdfs:label "dependsOn" ;
    rdfs:domain :Component ;
    rdfs:range :Component .
:implements a owl:ObjectProperty ;
    rdfs:label "implements" ;
    rdfs:domain :Component ;
    rdfs:range :Interface .
:uses a owl:ObjectProperty ;
    rdfs:label "uses" ;
    rdfs:domain :Component ;
    rdfs:range :Interface ;
    rdfs:subPropertyOf cco:ont00001813 {| trivyn:confidence "0.95"^^xsd:decimal ; trivyn:parentLabel "uses" ; skos:historyNote "Aligned to uses via embedding similarity" ; dcterms:created "2026-06-16T19:35:29Z"^^xsd:dateTime |}.
:accesses a owl:ObjectProperty ;
    rdfs:label "accesses" ;
    rdfs:domain :Component ;
    rdfs:range :DataStore .
:exposes a owl:ObjectProperty ;
    rdfs:label "exposes" ;
    rdfs:domain :Service ;
    rdfs:range :Interface .
:moduleContains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:domain :Module ;
    rdfs:range :Module ;
    rdfs:subPropertyOf obo:BFO_0000178 {| trivyn:confidence "0.70"^^xsd:decimal ; trivyn:parentLabel "has continuant part" ; trivyn:rrfRank "2"^^xsd:integer ; skos:historyNote "Aligned to has continuant part via embedding similarity" ; dcterms:created "2026-06-16T19:35:29Z"^^xsd:dateTime |}.
:containedInSoftwareSystem a owl:ObjectProperty ;
    rdfs:label "is part of" ;
    owl:inverseOf :softwareSystemContains ;
    rdfs:domain :Subsystem ;
    rdfs:range :SoftwareSystem ;
    rdfs:subPropertyOf obo:BFO_0000176 ;
    skos:definition "Relates a subsystem to the software system that contains it." ;
    skos:altLabel "contained in" ;
    skos:historyNote "Logical inverse of :softwareSystemContains; subProperty of 'continuant part of' (BFO_0000176), the BFO inverse of 'has continuant part' (BFO_0000178)." .

 :containedInSubsystem a owl:ObjectProperty ;
    rdfs:label "is part of" ;
    owl:inverseOf :subsystemContains ;
    rdfs:domain :Component ;
    rdfs:range :Subsystem ;
    rdfs:subPropertyOf obo:BFO_0000176 ;
    skos:definition "Relates a component to the subsystem that contains it." ;
    skos:altLabel "contained in" ;
    skos:historyNote "Logical inverse of :subsystemContains; subProperty of 'continuant part of' (BFO_0000176)." .

 :containedInModule a owl:ObjectProperty ;
    rdfs:label "is part of" ;
    owl:inverseOf :moduleContains ;
    rdfs:domain :Module ;
    rdfs:range :Module ;
    rdfs:subPropertyOf obo:BFO_0000176 ;
    skos:definition "Relates a module to the module that contains it." ;
    skos:altLabel "contained in" ;
    skos:historyNote "Logical inverse of :moduleContains; subProperty of 'continuant part of' (BFO_0000176)." .
 
 :isDependencyOf a owl:ObjectProperty ;
    rdfs:label "is dependency of" ;
    owl:inverseOf :dependsOn ;
    rdfs:domain :Component ;
    rdfs:range :Component ;
    skos:definition "Relates a component to another component that depends on it." ;
    skos:altLabel "is depended on by" .

 :isImplementedBy a owl:ObjectProperty ;
    rdfs:label "is implemented by" ;
    owl:inverseOf :implements ;
    rdfs:domain :Interface ;
    rdfs:range :Component ;
    skos:definition "Relates an interface to a component that implements it." .

 :isUsedBy a owl:ObjectProperty ;
    rdfs:label "is used by" ;
    owl:inverseOf :uses ;
    rdfs:domain :Interface ;
    rdfs:range :Component ;
    skos:definition "Relates an interface to a component that uses it." .
 :isAccessedBy a owl:ObjectProperty ;
    rdfs:label "is accessed by" ;
    owl:inverseOf :accesses ;
    rdfs:domain :DataStore ;
    rdfs:range :Component ;
    skos:definition "Relates a data store to a component that accesses it." .

 :isExposedBy a owl:ObjectProperty ;
    rdfs:label "is exposed by" ;
    owl:inverseOf :exposes ;
    rdfs:domain :Interface ;
    rdfs:range :Service ;
    skos:definition "Relates an interface to the service that exposes it." .

# Competency questions this ontology was built to answer (synthesis).
<https://trivyn.io/ontologies/software/engineering/domain/>
    <https://trivyn.io/ontologies/toekg#satisfiesCompetencyQuestion> "Which components depend on a specific component?",
        "What interfaces are exposed by a given service?",
        "Which data stores are accessed by a specific component?",
        "What is the hierarchy of subsystems within a software system?",
        "Which components implement a particular interface?" .

