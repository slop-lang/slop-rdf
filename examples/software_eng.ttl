<https://trivyn.io/ontologies/software/engineering/domain/> a owl:Ontology ;
    rdfs:label "Domain Ontology (Clean Model)" ;
    rdfs:comment "Clean, publishable domain model with proper naming and domain ontology alignments" ;
    dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime ;
    dcterms:modified "2026-06-16T19:35:00Z"^^xsd:dateTime ;
    dcterms:creator "Trivyn Ontology Pipeline" ;
    dcterms:publisher "Trivyn" ;
    owl:versionInfo "0.8.0" ;
    dcterms:provenance """Generated by Trivyn v0.8.0 on 2026-06-16T19:35:00Z.
Sources: unknown sources.
Domain ontology: Core Ontologies (BFO + CCO).
Domain hint: The designed, logical structure of a software system — its architectural building blocks and how they relate, not source-code syntax or runtime behavior.
Core concepts: software system, subsystem, component, service, module/package, interface, data store. Core relationships: a component depends on other
components, is part of a system or subsystem, and exposes and/or implements interfaces. A reusable, general backbone intended to be extended later by
language-specific ontologies (e.g. a Rust module or Python class as kinds of module/component). Deliberately thin and general..
Core fallback: yes.
Mid-level clustering disabled.""" ;
    owl:imports <https://trivyn.io/ontologies/software/engineering/mapping/> .

# =============================================================================
# Annotation Property Definitions
# =============================================================================

trivyn:confidence a owl:AnnotationProperty ;
    rdfs:label "confidence score" ;
    rdfs:comment "Confidence score for automated alignments and equivalences (0.0-1.0)" ;
    rdfs:range xsd:decimal .

# =============================================================================
# Domain Ontology - Clean Publishable Model
# =============================================================================
# This ontology provides clean class/property names suitable for publication.
# Includes mid-level concepts and alignments to top-level ontologies (BFO/CCO).
# Keyless domain ontology — surrogate identifiers are confined to raw layer and bridged via owl:equivalentClass/Property axioms in mapping.ttl
# =============================================================================

# Classes
:SoftwareSystem a owl:Class ;
    rdfs:label "Software System" ;
    skos:definition "The highest-level logical aggregation of architectural building blocks that forms a complete application or platform." ;
    trivyn:labelProperty :hasSystemName ;
    skos:historyNote "Derived from synthesis source 'SoftwareSystem'" ;
    rdfs:subClassOf cco:ont00000958 {| trivyn:confidence "0.70"^^xsd:decimal ; trivyn:l0Category "record" ; trivyn:parentLabel "Information Content Entity" ; trivyn:rrfRank "2"^^xsd:integer ; skos:historyNote "Aligned to Information Content Entity via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:Subsystem a owl:Class ;
    rdfs:label "Subsystem" ;
    skos:definition "A major logical partition of a software system that groups related functionality." ;
    trivyn:labelProperty :hasSubsystemName ;
    skos:historyNote "Derived from synthesis source 'Subsystem'" ;
    rdfs:subClassOf cco:ont00000958 {| trivyn:confidence "0.75"^^xsd:decimal ; trivyn:l0Category "record" ; trivyn:parentLabel "Information Content Entity" ; trivyn:rrfRank "1"^^xsd:integer ; skos:historyNote "Aligned to Information Content Entity via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:Component a owl:Class ;
    rdfs:label "Component" ;
    skos:definition "A modular, deployable, or replaceable part of a system that encapsulates state and behavior." ;
    trivyn:labelProperty :hasComponentName ;
    skos:historyNote "Derived from synthesis source 'Component'" ;
    rdfs:subClassOf cco:ont00001069 {| trivyn:confidence "0.70"^^xsd:decimal ; trivyn:l0Category "record" ; trivyn:parentLabel "Representational Information Content Entity" ; trivyn:rrfRank "2"^^xsd:integer ; skos:historyNote "Aligned to Representational Information Content Entity via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:Service a owl:Class ;
    rdfs:label "Service" ;
    skos:definition "A component that provides a set of operations to other components, typically over a network boundary." ;
    skos:historyNote "Derived from synthesis source 'Service'" .

:Module a owl:Class ;
    rdfs:label "Module" ;
    skos:definition "A logical grouping of related code elements, such as packages or namespaces." ;
    trivyn:labelProperty :hasModuleName ;
    skos:historyNote "Derived from synthesis source 'Module'" .

:Interface a owl:Class ;
    rdfs:label "Interface" ;
    skos:definition "A contract that defines a set of operations or data formats without specifying the implementation." ;
    trivyn:labelProperty :hasInterfaceName ;
    skos:historyNote "Derived from synthesis source 'Interface'" ;
    rdfs:subClassOf cco:ont00000958 {| trivyn:confidence "0.60"^^xsd:decimal ; trivyn:l0Category "record" ; trivyn:parentLabel "Information Content Entity" ; trivyn:rrfRank "5"^^xsd:integer ; skos:historyNote "Aligned to Information Content Entity via embedding similarity" ; skos:editorialNote "LLM picked rank 5 — narrow candidate gap; manual review recommended" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:DataStore a owl:Class ;
    rdfs:label "Data Store" ;
    skos:definition "A logical entity used for the persistent storage and retrieval of data." ;
    skos:historyNote "Derived from synthesis source 'DataStore'" ;
    rdfs:subClassOf cco:ont00000958 {| trivyn:confidence "0.75"^^xsd:decimal ; trivyn:l0Category "record" ; trivyn:parentLabel "Information Content Entity" ; trivyn:rrfRank "1"^^xsd:integer ; skos:historyNote "Aligned to Information Content Entity via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:InterfaceDefinition a owl:Class ;
    rdfs:label "Interface Definition" ;
    skos:definition "The formal specification of an interface, such as a Swagger file or Protobuf definition." ;
    skos:historyNote "Derived from synthesis source 'InterfaceDefinition'" .

:ExternalDependency a owl:Class ;
    skos:prefLabel "ExternalDependency"@en ;
    rdfs:label "ExternalDependency" ;
    rdfs:subClassOf :Component ;
    trivyn:labelProperty :hasDependencyName ;
    prov:wasGeneratedBy trivyn:UserAuthoringActivity .

# Datatype Properties
