:hasServiceType a owl:DatatypeProperty ;
    rdfs:label "has service type" ;
    rdfs:domain :Service ;
    rdfs:range xsd:string ;
    skos:historyNote "Mapped from synthesis field 'Service.serviceType'" ;
    rdfs:subPropertyOf cco:ont00001765 {| trivyn:confidence "0.85"^^xsd:decimal ; trivyn:parentLabel "has text value" ; skos:historyNote "Aligned to has text value via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:hasSpecificationVersion a owl:DatatypeProperty ;
    rdfs:label "has specification version" ;
    rdfs:domain :InterfaceDefinition ;
    rdfs:range xsd:string ;
    skos:historyNote "Mapped from synthesis field 'InterfaceDefinition.specificationVersion'" ;
    rdfs:subPropertyOf cco:ont00001765 {| trivyn:confidence "0.85"^^xsd:decimal ; trivyn:parentLabel "has text value" ; skos:historyNote "Aligned to has text value via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:hasStorageType a owl:DatatypeProperty ;
    rdfs:label "has storage type" ;
    rdfs:domain :DataStore ;
    rdfs:range xsd:string ;
    skos:historyNote "Mapped from synthesis field 'DataStore.storageType'" ;
    rdfs:subPropertyOf cco:ont00001765 {| trivyn:confidence "0.85"^^xsd:decimal ; trivyn:parentLabel "has text value" ; skos:historyNote "Aligned to has text value via embedding similarity" ; dcterms:created "2026-06-16T19:35:00Z"^^xsd:dateTime |}.

:hasSubsystemName a owl:DatatypeProperty ;
